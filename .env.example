# ── Shared auth ───────────────────────────────────────────────────────────────
# Bearer token every client must send to Caddy. Generate: openssl rand -hex 32
SHARED_TOKEN=change-me-to-a-long-random-string

# ── GPU PC (LAN) ───────────────────────────────────────────────────────────────
# LAN IP or hostname of the GPU PC (the Windows machine with the RTX 3090).
GPU_PC_HOST=192.168.1.x
# LM Studio server port — set in LM Studio → Server settings (default 1234).
GPU_PC_LMSTUDIO_PORT=1234
# dino-worker FastAPI port — set in the C# agent config (default 8000).
GPU_PC_DINO_PORT=8000

# ── dino-worker ───────────────────────────────────────────────────────────────
# These are passed to the native Python process on the GPU PC (and also used
# if the Docker image from GHCR is ever deployed on a Linux GPU node).
#
# Hugging Face token (DINOv3 is gated): https://huggingface.co/settings/tokens
HF_TOKEN=
# DINOv3 checkpoint. ViT-B is lean (~0.5 GB); ViT-L is higher quality (~1.5 GB).
DINO_MODEL=facebook/dinov3-vitb16-pretrain-lvd1689m
# Seconds of inactivity before the worker unloads DINOv3 to free VRAM (0 = never).
DINO_IDLE_EVICT_SECONDS=600

# ── GHCR ──────────────────────────────────────────────────────────────────────
# Your GitHub username (lowercase). Matches the GHCR image prefix.
GHCR_OWNER=jsfrouws
