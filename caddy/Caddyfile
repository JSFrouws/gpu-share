{
	admin off
}

# Single auth boundary for LAN clients and the life-app backend on server.home.
# Every request must carry:  Authorization: Bearer <SHARED_TOKEN>
#
# Routes:
#   /v1/*   → LM Studio on the GPU PC  (LLM, embeddings — OpenAI-compatible API)
#   /dino/* → dino-worker on the GPU PC (DINOv3 image embeddings, prefix stripped)
:8088 {
	@unauthed not header Authorization "Bearer {$SHARED_TOKEN}"

	# Public gate — requests arriving via the Cloudflare tunnel always carry
	# CF-Connecting-IP; LAN requests never do. Tunnel traffic is only served
	# while /gate/tunnel-enabled exists (flag toggled by the life-app tunnel
	# button through the life-os api, shared host dir ./gate).
	@publicBlocked {
		header CF-Connecting-IP *
		not file {
			root /gate
			try_files tunnel-enabled
		}
	}

	# route preserves written order — without it Caddy's default directive order
	# runs handle/handle_path BEFORE respond, letting every request bypass the
	# token check straight into the proxy.
	route {
		respond @publicBlocked "Public access disabled" 403
		respond @unauthed "Unauthorized" 401

		handle_path /dino/* {
			reverse_proxy {$GPU_PC_HOST}:{$GPU_PC_DINO_PORT:8000}
		}

		handle {
			reverse_proxy {$GPU_PC_HOST}:{$GPU_PC_LMSTUDIO_PORT:1234}
		}
	}
}
